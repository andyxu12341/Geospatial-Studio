{
  "git": {
    "commitMessage": "chore: release v${version}",
    "requireCommits": true,
    "addUntrackedFiles": true,
    "push": true,
    "tag": true,
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "autoGenerate": true
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat", "section": "Features", "hidden": false },
          { "type": "fix", "section": "Bug Fixes", "hidden": false },
          { "type": "refactor", "section": "Technical Architecture", "hidden": false },
          { "type": "perf", "section": "Performance", "hidden": false },
          { "type": "docs", "section": "Documentation", "hidden": false },
          { "type": "test", "section": "Tests", "hidden": true },
          { "type": "build", "section": "Build System", "hidden": true },
          { "type": "ci", "section": "CI/CD", "hidden": true },
          { "type": "chore", "section": "Maintenance", "hidden": true }
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n\nThe format is based on [Conventional Commits](https://www.conventionalcommits.org/).\n",
      "ignoreRecommendedBump": true,
      "releaseCount": 0
    }
  },
  "hooks": {},
  "version": {
    "increment": "patch",
    "override": false
  },
  "changelog": {
    "showCommitLinks": true,
    "showAuthor": true
  }
}
